<%- include('partials/header', { pageTitle, activePage }) %>
<section class="section-block auth-section">
  <div class="container narrow-container">
    <div class="auth-card card-panel">
      <span class="eyebrow">Admin Access</span>
      <h1>Admin Login</h1>
      <p>Use the default credentials below for demonstration.</p>

      <div class="notice-card" style="margin-top: 1rem;">
        <strong>Default credentials</strong>
        <p style="margin: 0.5rem 0 0;">Username: <strong>admin</strong></p>
        <p style="margin: 0.25rem 0 0;">Password: <strong>admin123</strong></p>
      </div>

      <% if (errorMessage) { %>
        <div class="alert alert-error"><%= errorMessage %></div>
      <% } %>

      <form action="/admin/login" method="POST" class="form-grid">
        <div class="form-field full-width">
          <label for="username">Username</label>
          <input id="username" name="username" type="text" placeholder="Enter username" required>
        </div>
        <div class="form-field full-width">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" placeholder="Enter password" required>
        </div>
        <div class="full-width form-actions">
          <button class="btn btn-primary" type="submit">Login</button>
          <a class="btn btn-secondary" href="/">Back to Home</a>
        </div>
      </form>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
