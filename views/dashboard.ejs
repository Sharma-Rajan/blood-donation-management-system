<%- include('partials/header', { pageTitle, activePage }) %>
<section class="section-block">
  <div class="container">
    <div class="dashboard-header">
      <div>
        <span class="eyebrow">Admin Dashboard</span>
        <h1>Registered Donors</h1>
        <p>View all records, remove outdated entries, and keep the donor database clean.</p>
      </div>
      <div class="dashboard-actions">
        <a class="btn btn-secondary" href="/admin/logout">Logout</a>
      </div>
    </div>

    <% if (successMessage) { %>
      <div class="alert alert-success"><%= successMessage %></div>
    <% } %>

    <div class="table-card">
      <% if (donors.length) { %>
        <div class="table-responsive">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Blood Group</th>
                <th>City</th>
                <th>Created At</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% donors.forEach((donor) => { %>
                <tr>
                  <td><%= donor.id %></td>
                  <td><%= donor.name %></td>
                  <td><%= donor.email %></td>
                  <td><%= donor.phone %></td>
                  <td><span class="badge"><%= donor.blood_group %></span></td>
                  <td><%= donor.city %></td>
                  <td><%= new Date(donor.created_at).toLocaleString() %></td>
                  <td>
                    <form action="/admin/donor/<%= donor.id %>/delete" method="POST" data-delete-form>
                      <button class="btn btn-danger btn-small" type="submit">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <h2>No donors registered yet</h2>
          <p>Once donors register, their records will appear here.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
